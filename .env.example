# Copy to .env and fill in.

# Provider: none | openai | groq
ORCHESTRATOR_PROVIDER=groq

# Groq credentials and per-role model split.
# Router (small/fast)   = intent classification, persona inference, review critique.
# Generator (strong)    = review writing.
GROQ_API_KEY=
GROQ_ROUTER_MODEL=llama-3.1-8b-instant
GROQ_GENERATOR_MODEL=llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (only used when ORCHESTRATOR_PROVIDER=openai)
OPENAI_API_KEY=
ORCHESTRATOR_MODEL=gpt-4o-mini

# Task B stage-2 rerank (Groq two-step - uses GROQ_API_KEY above)
TASK_B_TOP_K=6

# Generator sampling controls - higher values = more diverse output.
GEN_TEMPERATURE=0.85
GEN_TOP_P=0.9
GEN_PRESENCE_PENALTY=0.6
GEN_FREQUENCY_PENALTY=0.5
GEN_MAX_TOKENS=320

# Review critique → regenerate loop.
REVIEW_CRITIQUE_ENABLED=true
REVIEW_CRITIQUE_THRESHOLD=4

# Optional Chroma (compose service hostname `chroma`)
CHROMA_HOST=
CHROMA_PORT=8000

# Comma-separated browser origins allowed to call the API.
# Local dev: leave the defaults; production: set to your deployed frontend URL,
# e.g. CORS_ORIGINS=https://naijasense-ai.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
